# =============================================================================
# Mattermost API 동작 테스트 환경변수 템플릿 (.env.example)
# -----------------------------------------------------------------------------
# 1. 이 파일을 복사해서 .env 로 만든다:  cp .env.example .env
# 2. 아래 값들을 실제 값으로 채운다.
# 3. .env 는 .gitignore 에 의해 커밋되지 않는다. 절대 저장소에 올리지 말 것.
# =============================================================================

# [필수] Mattermost 인스턴스의 base URL.
# SSAFY 예시: https://meeting.ssafy.com
# 끝에 슬래시(/)는 붙이지 않는다.
MATTERMOST_BASE_URL=https://meeting.ssafy.com

# [필수] Personal Access Token.
# Mattermost 프로필 > 설정 > 보안 > Personal Access Tokens 에서 발급.
# (계정 설정 > Security > Personal Access Tokens)
# self-hosted 에서는 관리자가 "Enable Personal Access Tokens: true" 로 설정해야 함.
# 아래 값을 본인이 발급한 실제 토큰으로 교체하세요. .env.example 은 커밋되므로
# 절대 실제 토큰을 여기에 두지 말 것.
MATTERMOST_TOKEN=your-personal-access-token-here

# [선택] 테스트 대상 팀 ID.
# 비워두면 소속 팀(/users/me/teams) 중 첫 팀을 자동 선택한다.
MATTERMOST_TEST_TEAM_ID=

# [선택] 테스트 대상 채널 ID.
# 비워두면 대상 팀의 일반 채널(type O/P) 중 첫 채널을 자동 선택한다.
# 쓰기 테스트(webhook/posts)에서 실제 메시지가 게시되므로 테스트 전용 채널 권장.
MATTERMOST_TEST_CHANNEL_ID=

# [선택] HTTP 요청 타임아웃 (초). 기본 30.
REQUEST_TIMEOUT=30

# [선택] 목록 조회 시 페이지당 항목 수. 기본 60. (최대 200)
PER_PAGE=60

# [선택, webhook 전송 테스트 전용] incoming webhook 의 전체 URL.
# 형식: https://meeting.ssafy.com/hooks/{webhook_id}/{webhook_token}
# 이 값이 설정된 경우에만 test_webhooks.py 가 webhook으로 실제 메시지 전송(ping)을 수행한다.
# webhook 생성 응답에는 token이 없으므로, Mattermost UI에서 webhook URL을 복사해 넣어야 한다.
MATTERMOST_WEBHOOK_URL=
