# =============================================================================
# Jira Cloud API 동작 테스트 환경변수 템플릿 (.env.example)
# -----------------------------------------------------------------------------
# 1. 이 파일을 복사해서 .env 로 만든다:  cp .env.example .env
# 2. 아래 값들을 실제 값으로 채운다.
# 3. .env 는 .gitignore 에 의해 커밋되지 않는다. 절대 저장소에 올리지 말 것.
# =============================================================================

# [필수] Jira Cloud 인스턴스의 base URL.
# SSAFY 예시: https://ssafy.atlassian.net
# 끝에 슬래시(/)는 붙이지 않는다.
JIRA_BASE_URL=https://ssafy.atlassian.net

# [필수] OAuth 2.0 Access Token
# Atlassian OAuth 2.0 (3LO) 흐름을 통해 발급받은 액세스 토큰.
# 기본 만료 1시간(3600초). 만료되어 401 이 돌아오면 refresh 설정(아래)이 있으면
# jira_client.py 가 자동으로 갱신하고 이 .env 의 값을 덮어쓴다.
JIRA_OAUTH_TOKEN=

# [필수] Jira Cloud ID (UUID 형식)
# OAuth 2.0으로 API 호출 시 대상 Jira 인스턴스를 지정하기 위한 식별자.
# accessible-resources API(https://api.atlassian.com/oauth/token/accessible-resources)를 통해 확인할 수 있습니다.
JIRA_CLOUD_ID=

# [선택, 자동 갱신용] OAuth 2.0 Refresh Token.
# access_token 만료(401) 시 자동 갱신에 사용. 아래 3개 변수를 모두 채워야 자동 갱신 동작.
# 주의: refresh 호출은 rotate-on-use 로 기존 refresh_token 이 무효화되므로, 갱신 성공 시
# 이 .env 의 값이 자동으로 새 토큰으로 덮어쓰기됨.
# 최초 authorization URL 의 scope 에 offline_access 가 포함되어 있어야 발급됨.
JIRA_OAUTH_REFRESH_TOKEN=

# [선택, 자동 갱신용] OAuth 2.0 앱의 Client ID (Atlassian Developer Console > Settings).
JIRA_OAUTH_CLIENT_ID=

# [선택, 자동 갱신용] OAuth 2.0 앱의 Client Secret.
# 절대 이 파일(.env.example)에 실제 secret 을 두지 말 것 — .env(비커밋)에만.
JIRA_OAUTH_CLIENT_SECRET=

# [선택] 테스트 대상 프로젝트 키.
# SSAFY 예시: S15P11A502
# 비워두면 접근 가능한 프로젝트(/project/search) 중 첫 프로젝트를 자동 선택한다.
JIRA_TEST_PROJECT_KEY=S15P11A502

# [선택] HTTP 요청 타임아웃 (초). 기본 30.
REQUEST_TIMEOUT=30

# [선택] JQL 검색 등 목록 조회 시 페이지당 최대 항목 수. 기본 50.
MAX_RESULTS=50
