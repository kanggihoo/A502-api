# =============================================================================
# Notion API 동작 테스트 환경변수 템플릿 (.env.example)
# -----------------------------------------------------------------------------
# 1. 이 파일을 복사해서 .env 로 만든다:  cp .env.example .env
# 2. 아래 값들을 실제 값으로 채운다.
# 3. .env 는 .gitignore 에 의해 커밋되지 않는다. 절대 저장소에 올리지 말 것.
# =============================================================================

# [필수] Notion Bearer 토큰.
# 두 가지 중 하나를 넣으면 된다 (클라이언트 코드는 동일하게 동작):
#   - Internal connection installation token (Developer portal → Configuration)
#   - OAuth 2.0 access_token (Postman 등으로 발급받은 것. docs/notion-oauth-postman.md 참고)
NOTION_API_KEY=

# [선택] Notion REST API base URL. 기본 https://api.notion.com/v1
NOTION_BASE_URL=https://api.notion.com/v1

# [선택] Notion-Version 헤더값. 기본 2026-03-11
NOTION_API_VERSION=2026-03-11

# [선택] 검증 대상 페이지 ID (UUID).
# 비워두면 POST /search 결과에서 접근 가능한 첫 페이지를 자동 선택한다.
# 페이지를 Integration/OAuth 연결에 미리 공유(Add connection)해야 한다.
NOTION_TEST_PAGE_ID=

# [선택] 검증 대상 데이터베이스 ID (UUID).
# 비워두면 POST /search 결과에서 접근 가능한 첫 database 를 자동 선택한다.
NOTION_TEST_DATABASE_ID=

# [선택] HTTP 요청 타임아웃 (초). 기본 30.
REQUEST_TIMEOUT=30

# [선택] 목록 조회 페이지 사이즈. Notion 은 최대 100. 기본 10.
MAX_RESULTS=10


# =============================================================================
# OAuth 2.0 전용 (test_oauth_token.py + docs/notion-oauth-postman.md 용, 선택)
# -----------------------------------------------------------------------------
# Public connection 으로 OAuth 를 검증할 때만 채운다.
# Internal token 만 쓸 때는 비워둬도 된다.
# =============================================================================

# Public connection 의 CLIENT_ID (Developer portal → Configuration)
NOTION_OAUTH_CLIENT_ID=

# Public connection 의 CLIENT_SECRET
NOTION_OAUTH_CLIENT_SECRET=

# 인가 코드 교환으로 받은 refresh_token (access_token 갱신 검증에 사용)
NOTION_OAUTH_REFRESH_TOKEN=

# Public connection 에 등록한 redirect_uri (Postman 콜백 등)
NOTION_OAUTH_REDIRECT_URI=
