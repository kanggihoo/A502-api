# =============================================================================
# GitLab API 동작 테스트 환경변수 템플릿 (.example.env)
# -----------------------------------------------------------------------------
# 1. 이 파일을 복사해서 .env 로 만든다:  cp .example.env .env
# 2. 아래 값들을 실제 값으로 채운다.
# 3. .env 는 .gitignore 에 의해 커밋되지 않는다. 절대 저장소에 올리지 말 것.
# =============================================================================

# [필수] GitLab 인스턴스의 base URL.
# SSAFY 예시: https://lab.ssafy.com
# 끝에 슬래시(/)는 붙이지 않는다.
GITLAB_BASE_URL=https://lab.ssafy.com

# [필수] 인증 방식 선택. "pat" 또는 "oauth2".
# - pat (기본값): Personal Access Token. 1회성 스크립트·긴급 디버그 용도.
# - oauth2:       OAuth2 access_token. 제품(통합 워크스페이스)용. priority-filter.md
#                 의 "POC 는 처음부터 OAuth2" 방향. access_token 만료 시 refresh_token
#                 으로 자동 갱신(1회) 후 재시도.
GITLAB_AUTH_METHOD=pat


# =============================================================================
# PAT 모드 (GITLAB_AUTH_METHOD=pat 일 때 사용)
# =============================================================================
# GitLab 프로필 > Access Tokens 에서 발급.
# 필요 scope(읽기 전용): read_api, read_user, read_repository
# webhook 검증 추가 시:  api (쓰기 권한)
# 아래 값을 본인이 발급한 실제 토큰으로 교체. 절대 실제 토큰을 여기에 두지 말 것.
GITLAB_TOKEN=your-personal-access-token-here


# =============================================================================
# OAuth2 모드 (GITLAB_AUTH_METHOD=oauth2 일 때 사용)
# -----------------------------------------------------------------------------
# Postman 등으로 Authorization Code + PKCE flow 를 거쳐 얻은 토큰을 아래에 넣는다.
# (GitLab UI > User Settings > Applications 에서 등록한 사용자 수준 OAuth 앱 기준)
#
# access_token 은 기본 2시간(7200초) 후 만료. 만료되어 401 이 돌아오면
# gitlab_client.py 가 refresh_token + client_id (및 client_secret) 로 자동 갱신하고
# 새 토큰 쌍을 이 .env 에 다시 덮어쓴다(GitLab refresh 는 rotate-on-use 이므로 영속화 필수).
#
# scope 예시(권장): read_api (읽기 대시보드) | api (쓰기, 팀장만)
# =============================================================================

# [oauth2 필수] OAuth2 앱의 client_id (앱 등록 시 발급되는 Application ID).
GITLAB_OAUTH_CLIENT_ID=

# [oauth2 갱신용] OAuth2 앱의 client_secret (Confidential 앱만).
# Postman flow 에서 쓴 것과 동일한 값. Public/PKCE-only 앱이면 비워도 됨.
GITLAB_OAUTH_CLIENT_SECRET=

# [oauth2 갱신용] refresh 시 원래 authorization 요청과 동일해야 하는 redirect_uri.
# Postman flow 의 callback URL 과 일치시킬 것. 비워도 refresh 자체는 동작할 수 있음.
GITLAB_OAUTH_REDIRECT_URI=

# [oauth2 필수] access_token. Postman 의 "Manage Tokens" 또는 token 교환 응답에서 복사.
# 절대 실제 토큰을 이 파일(.example.env)에 하드코딩하지 말 것 — .env(비커밋)에만.
GITLAB_OAUTH_ACCESS_TOKEN=

# [oauth2 갱신용] refresh_token. 자동 갱신을 쓰지 않아도 만료 시 Postman 에서 다시
# 받아 수동으로 갱신할 수 있다. 자동 갱신을 쓰려면 필수.
GITLAB_OAUTH_REFRESH_TOKEN=


# =============================================================================
# 공통 설정 (두 모드 모두)
# =============================================================================

# [선택] 테스트 대상 프로젝트 ID 또는 URL-encoded path.
# 예(숫자 ID): 1234
# 예(경로): team%2Fa502%2Fbackend  (슬래시는 %2F 로 인코딩)
# 비워두면 접근 가능한 프로젝트(membership=true) 중 첫 프로젝트를 자동 선택한다.
GITLAB_TEST_PROJECT_ID=

# [선택] HTTP 요청 타임아웃 (초). 기본 30.
REQUEST_TIMEOUT=30

# [선택] 목록 조회 시 페이지당 항목 수. 기본 20. (최대 100)
PER_PAGE=20

# [선택, webhook 테스트 전용] webhook이 이벤트를 보낼 수신 엔드포인트 URL.
# 이 값이 설정된 경우에만 test_webhooks.py 가 실제로 webhook 생성/삭제를 수행한다.
# 예: https://your-webhook-receiver.example.com/gitlab
# 비워두면 webhook 쓰기 테스트를 건너뛴다.
WEBHOOK_TEST_URL=
