          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/hooks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v4", "projects", "{{projectId}}", "hooks"]
            },
            "description": "프로젝트에 등록된 웹훅 목록을 조회한다. 프로젝트 Maintainer / Owner."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
