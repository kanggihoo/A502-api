    {
      "name": "File Uploads & Downloads (57 ~ 63)",
      "description": "프로젝트 관련 첨부파일 업로드 인증, 업로드, 목록 조회, 다운로드 및 삭제. 프로젝트 멤버 (Developer 이상).",
      "item": [
        {
          "name": "57. Authorize a project upload",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/uploads/authorize",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v4", "projects", "{{projectId}}", "uploads", "authorize"]
            },
            "description": "프로젝트 첨부파일 업로드 인증(authorize) 단계. 직접 업로드(58번) 전 사전 인증에 사용. 프로젝트 멤버 (Developer 이상)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/uploads/authorize",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v4", "projects", "{{projectId}}", "uploads", "authorize"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": 1,\n  \"status\": \"authorize\",\n  \"url\": \"https://example.com/upload/location\"\n}"
            }
          ]
        },
        {
          "name": "58. Upload a file",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "업로드할 파일" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/uploads",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v4", "projects", "{{projectId}}", "uploads"]
            },
            "description": "프로젝트에 첨부파일을 업로드한다. multipart/form-data로 file 전송. 프로젝트 멤버 (Developer 이상)."
          },
          "response": [
