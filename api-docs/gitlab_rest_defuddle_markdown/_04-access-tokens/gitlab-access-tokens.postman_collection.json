    {
      "name": "Project Access Tokens",
      "description": "프로젝트 액세스 토큰 관련 API (15, 17, 18, 19, 20, 21)",
      "item": [
        {
          "name": "15. Rotate project access token (Self)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/access_tokens/self/rotate",
              "host": ["{{baseUrl}}"],
              "path": [
                "api", "v4", "projects", "{{projectId}}", "access_tokens", "self", "rotate"
              ]
            },
            "description": "프로젝트 액세스 토큰 자체를 사용해 자기 자신 회전. self_rotate 스코프 필요. 헤더의 토큰이 즉시 무효화됨.\n\n⚠️ OAuth2 access_token으로는 동작하지 않음 — 요청 헤더에 Project Access Token 자체를 Bearer로 넣어야 함 (컬렉션 레벨 Bearer를 override하거나 별도 환경 필요)."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/access_tokens/self/rotate", "host": ["{{baseUrl}}"], "path": ["api", "v4", "projects", "{{projectId}}", "access_tokens", "self", "rotate"] } },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": 401,\n  \"name\": \"project-bot\",\n  \"token\": \"glpat-selfrotated123\",\n  \"active\": true\n}"
            }
          ]
        },
        {
          "name": "17. List all project access tokens",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/access_tokens",
              "host": ["{{baseUrl}}"],
              "path": [
                "api", "v4", "projects", "{{projectId}}", "access_tokens"
