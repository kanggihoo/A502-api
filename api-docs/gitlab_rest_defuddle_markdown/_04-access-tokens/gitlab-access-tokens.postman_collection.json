              "host": ["{{baseUrl}}"],
              "path": [
                "api", "v4", "groups", "{{groupId}}", "service_accounts", "{{saUserId}}", "personal_access_tokens"
              ]
            },
            "description": "그룹 서비스 계정 PAT 목록 조회. Group Owner 이상 필요."
          },
          "response": []
        },
        {
