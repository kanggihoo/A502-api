              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"id\": 302,\n  \"name\": \"ci-bot-token\",\n  \"token\": \"glpat-groupsa123456\",\n  \"active\": true,\n  \"expires_at\": \"2026-12-31\"\n}"
            }
          ]
        },
        {
          "name": "13. Revoke PAT for group service account",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v4/groups/{{groupId}}/service_accounts/{{saUserId}}/personal_access_tokens/{{tokenId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api", "v4", "groups", "{{groupId}}", "service_accounts", "{{saUserId}}", "personal_access_tokens", "{{tokenId}}"
              ]
            },
            "description": "그룹 서비스 계정 PAT 폐기. 204 No Content. Group Owner 필요."
          },
          "response": [
            {
              "name": "204 No Content",
              "originalRequest": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/api/v4/groups/{{groupId}}/service_accounts/{{saUserId}}/personal_access_tokens/{{tokenId}}", "host": ["{{baseUrl}}"], "path": ["api", "v4", "groups", "{{groupId}}", "service_accounts", "{{saUserId}}", "personal_access_tokens", "{{tokenId}}"] } },
              "status": "No Content",
