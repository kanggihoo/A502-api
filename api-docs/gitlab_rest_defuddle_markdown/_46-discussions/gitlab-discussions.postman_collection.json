              "body": "[\n  {\n    \"id\": 1001,\n    \"body\": \"이 부분 널 체크 필요해 보입니다.\",\n    \"author\": { \"id\": 12, \"username\": \"kkh_ssafy\" },\n    \"created_at\": \"2026-07-23T10:00:00Z\"\n  }\n]"
            }
          ]
        },
        {
