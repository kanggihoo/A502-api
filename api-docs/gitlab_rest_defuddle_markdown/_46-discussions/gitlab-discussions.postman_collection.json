              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/merge_requests/{{mergeRequestIid}}/discussions/{{discussionId}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v4", "projects", "{{projectId}}", "merge_requests", "{{mergeRequestIid}}", "discussions", "{{discussionId}}", "notes"]
