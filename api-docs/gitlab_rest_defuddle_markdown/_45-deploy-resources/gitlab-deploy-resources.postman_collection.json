        },
        {
          "name": "05. Update a deployment status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"success\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/deployments/{{deploymentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v4", "projects", "{{projectId}}", "deployments", "{{deploymentId}}"]
            },
            "description": "배포 상태를 업데이트한다. status 값: running | success | failed | canceled. 프로젝트 멤버 (Developer 이상)."
