              "name": "200 OK",
              "originalRequest": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"status\": \"success\"\n}" },
                "url": {
                  "raw": "{{baseUrl}}/api/v4/projects/{{projectId}}/deployments/{{deploymentId}}",
